# Copy to .env for local docker-compose overrides only — do not commit .env.
# For cloud hosting, set these in the platform’s dashboard (secrets / env vars).

# --- Backend (Flask / Gunicorn) ---
PORT=8000
FLASK_DEBUG=0
FLASK_SSL_ADHOC=0

# Google Sign-In: Web client ID used by the backend to verify id_token (must match your OAuth client).
GOOGLE_OAUTH_CLIENT_ID=

# Uploads: require HTTPS for non-local clients (keep 1 in production).
REQUIRE_HTTPS_UPLOADS=1

# Dev-only: allow HTTP from private LAN (192.168.x, etc.). Use 0 in production.
ALLOW_HTTP_PRIVATE_LAN=0

# Dataset for real ML paths (must exist with EEG/ and speech_data/ unless you accept demo mode).
# Docker compose example mounts host path to /data/dataset
DATASET_PATH=/data/dataset

# Optional Gunicorn tuning
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120

# --- Flutter build-time (not read by Flask; pass to flutter build/run) ---
# API_BASE_URL=https://your-api-host.example.com/api
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_SERVER_CLIENT_ID=
