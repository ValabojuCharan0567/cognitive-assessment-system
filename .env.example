# =============================================================================
# Cognitive Assessment System — environment template
# =============================================================================
# 1. Copy to `.env` in the REPOSITORY ROOT (same folder as README.md):
#      cp .env.example .env
# 2. Fill in secrets. Never commit `.env` (it is gitignored).
# 3. Flask loads this file automatically when you run `backend/api/app.py` or
#    Gunicorn, as long as `python-dotenv` is installed (`pip install -r backend/requirements.txt`).
#
# Render / Railway: set the same keys in the host dashboard (no .env file there).
# =============================================================================

# --- Flask / Gunicorn ---
PORT=8000
FLASK_DEBUG=1
FLASK_SSL_ADHOC=0

# --- Google Sign-In (backend verifies id_token against this Web client) ---
GOOGLE_OAUTH_CLIENT_ID=

# --- HTTPS / uploads (production: REQUIRE_HTTPS_UPLOADS=1, ALLOW_HTTP_PRIVATE_LAN=0) ---
REQUIRE_HTTPS_UPLOADS=1
ALLOW_HTTP_PRIVATE_LAN=1

# --- Dataset (full ML: folder must contain EEG/ and speech_data/) ---
# Local dev:
DATASET_PATH=/Users/you/Datasets/CognitiveAssessment
# Render when dataset is baked into the image (repo data/ — see backend/Dockerfile):
# DATASET_PATH=/workspace/data

# --- Docker Compose only (host path mounted as /data/dataset in the container) ---
HOST_DATASET_PATH=/Users/you/Datasets/CognitiveAssessment

# --- Optional Gunicorn (Render free 512MB: prefer WORKERS=1 to reduce OOM during audio ML) ---
# GUNICORN_WORKERS=1
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=300
# GUNICORN_LOG_LEVEL=info
# GUNICORN_PRELOAD=1

# =============================================================================
# Flutter — NOT read from this file by Python. Pass at build/run time, e.g.:
#   flutter run --dart-define=API_BASE_URL=http://127.0.0.1:8000/api \
#     --dart-define=GOOGLE_SERVER_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
# =============================================================================
# API_BASE_URL=http://127.0.0.1:8000/api
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_SERVER_CLIENT_ID=
